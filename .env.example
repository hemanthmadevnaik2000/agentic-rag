# ---- Postgres ----
DATABASE_URL=postgresql://rag:rag@localhost:5432/rag

# ---- Redis (arq worker / future semantic cache) ----
REDIS_URL=redis://localhost:6379/0

# ---- Milvus ----
MILVUS_URI=http://localhost:19530
MILVUS_TOKEN=

# ---- Elasticsearch (BM25) ----
ELASTICSEARCH_URL=http://localhost:9200
ENABLE_BM25=true

# ---- Secrets encryption ----
# Comma-separated Fernet keys, NEWEST FIRST (MultiFernet: first encrypts, all decrypt).
# Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_ENCRYPTION_KEYS=

# ---- Embeddings / reranker ----
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
EMBEDDING_DIM=768
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# ---- Retrieval params ----
RETRIEVAL_TOP_K=5
RETRIEVAL_CANDIDATES=20
RRF_K=60

# ---- Tracing (LangSmith) ----
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=agentic-rag

# ---- Dev fallback provider keys (registered LLMs live in the DB) ----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---- Sessions / semantic cache ----
SESSION_TTL_SECONDS=86400
SEMANTIC_CACHE_ENABLED=true
SEMANTIC_CACHE_TTL_SECONDS=3600
SEMANTIC_CACHE_MAX_DISTANCE=0.1
